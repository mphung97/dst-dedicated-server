# Don't Starve Together Dedicated Server - Docker Environment Configuration
# Copy this file to .env and customize for your deployment

# Server Identification
CLUSTER_NAME=DSTCluster
GAME_SERVER_NAME=World of PopPop
GAME_SERVER_DESC=A DST dedicated server with Master + Caves

# Game Settings
GAME_MODE=survival
PVP_ENABLED=false

# Authentication (REQUIRED - obtain from Klei account)
CLUSTER_TOKEN=your_cluster_token_here

# Port Configuration
MASTER_PORT=10999
MASTER_TCP_PORT=8765
CAVES_PORT=11000
CAVES_TCP_PORT=8766

# Player Management
# Comma or space-separated list of player IDs
ADMIN_LIST=
WHITELIST_LIST=
BLOCKLIST=

# Local Game Directory (for development/initial config)
# Maps to container /app/game.mount for initial setup
# Relative paths are from docker-compose.yml location
LOCAL_GAME_DIR=.

# Advanced: Resource Limits (Docker Compose)
# Uncomment and set these in docker-compose override or via -e flags
# COMPOSE_MEMORY_LIMIT=2g
# COMPOSE_CPUS_LIMIT=2
